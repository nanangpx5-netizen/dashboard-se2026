RewriteEngine On

# Redirect trailing slashes
RewriteRule ^(.+)/$ $1 [L,R=301]

# Test connection route — shared database
RewriteRule ^test-connection/?$ public/index.php [L,QSA]

# Deny direct access to app, src, config, storage, views
RewriteRule ^(app|src|config|storage|views|vendor) - [F,L]

# If file or directory exists, serve directly
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Route everything to index.php
RewriteRule ^(.*)$ index.php?url=$1 [QSA,L]

# Security headers
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# Deny access to .env, SQL, cache, and log files
<FilesMatch "\.(env|sql|md|log|cache)$">
    Require all denied
</FilesMatch>
