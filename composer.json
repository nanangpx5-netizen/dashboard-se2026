{
    "name": "bps-jember/dashboard-se2026",
    "description": "Dashboard Sensus Ekonomi 2026 BPS Kabupaten Jember",
    "type": "project",
    "require": {
        "php": "^8.2",
        "openspout/openspout": "^4.24",
        "ext-pdo": "*",
        "ext-mbstring": "*",
        "dompdf/dompdf": "^3.1"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        },
        "files": [
            "src/Helpers/helpers.php"
        ]
    },
    "config": {
        "optimize-autoloader": true
    },
    "require-dev": {
        "phpunit/phpunit": "11.0"
    }
}
