# ─────────────────────────────────────────────────────────────
#  Dashboard SE2026 — Environment Configuration (TEMPLATE)
#  Copy to .env and fill in your actual values
# ─────────────────────────────────────────────────────────────

# ─── Database ────────────────────────────────────────────────
# Primary keys (DB_DATABASE/DB_USERNAME/DB_PASSWORD) take priority
# Old keys (DB_NAME/DB_USER/DB_PASS) are still supported as fallback
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=bps_jember_se2026
DB_USERNAME=root
DB_PASSWORD=

# ─── Application ─────────────────────────────────────────────
APP_NAME="Dashboard SE2026 Jember"
APP_ENV=production
APP_DEBUG=false
BASE_URL=/dashboard-se2026/

# ─── Session ─────────────────────────────────────────────────
# Session lifetime in seconds (default: 2 hours = 7200)
SESSION_LIFETIME=7200

# ─── Security Headers ────────────────────────────────────────
# Content-Security-Policy (CSP)
# Set CSP_ENABLED=false only for local debugging
CSP_ENABLED=true
# CSP_DIRECTIVES can be overridden; default covers Bootstrap, DataTables,
# jQuery, Chart.js, Leaflet, Select2, FontAwesome from CDNs
# CSP_DIRECTIVES="default-src 'self'; script-src 'self' ..."

# ─── CORS (if needed for API consumers) ──────────────────────
# Comma-separated list of allowed origins (empty = same-origin only)
CORS_ALLOWED_ORIGINS=
